# Server Port
PORT=3001

# Dashboard Authentication
DASHBOARD_USER=admin
DASHBOARD_PASS=change-this-to-a-secure-password

# Nginx Upstream Configuration Path
# In production, set to /etc/nginx/conf.d/mathswithsd-upstream.conf
# For local testing, use a path within the workspace directory
NGINX_UPSTREAM_CONF_PATH=./mathswithsd-upstream.conf

# Nginx Commands (for safety checks and reloading config)
# In production: "sudo nginx -t" and "sudo systemctl reload nginx"
# For local testing: "echo 'Nginx OK' && true" and "echo 'Nginx Reloaded' && true"
NGINX_TEST_CMD=echo 'Nginx test simulated successfully' && true
NGINX_RELOAD_CMD=echo 'Nginx reload simulated successfully' && true

# PM2 command (in production typically "pm2" or path to PM2)
# For local testing, if PM2 is not installed, it falls back to mock execution
PM2_CMD=pm2

# App environment
NODE_ENV=production
